# --- Places autocomplete (Book page) — recommended ---
# Server-only key: not exposed in the browser, so HTTP referrer restrictions on the key are NOT required.
# In Google Cloud: enable Places API; restrict this key to "Places API" only; Application restrictions = None.
# See GOOGLE-APIS.md
# PLACES_SERVER_API_KEY=
# Optional alias for the same key:
# GOOGLE_PLACES_SERVER_KEY=
# If you still only have the old browser key set, the server will try it last (Places REST may fail if that key is HTTP-referrer–only):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: extra hostnames allowed to call /api/places/* (comma-separated suffixes), e.g. myotherdomain.com
# PLACES_ALLOWED_HOST_SUFFIXES=

# --- Legacy (unused by Book autocomplete; you can remove) ---
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Analytics 4 ---
# When set, AnalyticsPlaceholder loads gtag.
# NEXT_PUBLIC_GA_ID=

# Your live domain (no trailing slash). Set this in Vercel → Settings → Environment Variables when you connect a custom domain.
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
