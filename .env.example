# --- Google Maps / Places (address autocomplete on Book page) ---
# Create a key in Google Cloud Console; enable Maps JavaScript API + Places API.
# See GOOGLE-APIS.md for full steps.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Analytics 4 ---
# When set, AnalyticsPlaceholder loads gtag.
# NEXT_PUBLIC_GA_ID=

# Your live domain (no trailing slash). Set this in Vercel → Settings → Environment Variables when you connect a custom domain.
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
